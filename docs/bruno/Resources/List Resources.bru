meta {
  name: List Resources
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/resources/?limit=20&offset=0
  body: none
  auth: none
}

params:query {
  limit: 20
  offset: 0
  ~category_id: 
  ~tag_ids: 
  ~search: 
  ~type: 
  ~sort: newest
}

example {
  name: List All Resources
  request: {
    url: {{base_url}}/api/resources/?limit=20&offset=0
